---
import type { Lang } from "../i18n/strings";
import { ui } from "../i18n/strings";
import { getLogicalPath, pathForLang } from "../i18n/paths";

const { title, description, lang = "zh" } = Astro.props as {
  title: string;
  description?: string;
  lang?: Lang;
};

const t = ui[lang];
const logical = getLogicalPath(Astro.url.pathname);
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    <meta name="color-scheme" content="light dark" />
    <link rel="alternate" hreflang="zh-CN" href={pathForLang(logical, "zh")} />
    <link rel="alternate" hreflang="en" href={pathForLang(logical, "en")} />
    <script is:inline>
      (() => {
        const key = "codesnip-theme";
        const root = document.documentElement;
        const readPref = () => {
          const v = localStorage.getItem(key);
          return v === "light" || v === "dark" || v === "system" ? v : "system";
        };
        const apply = (pref) => {
          const dark = pref === "dark" || (pref === "system" && window.matchMedia("(prefers-color-scheme: dark)").matches);
          root.classList.toggle("dark", dark);
          root.dataset.theme = pref;
        };
        apply(readPref());
      })();
    </script>
  </head>
  <body class="min-h-dvh bg-zinc-50 text-zinc-900 antialiased transition-colors dark:bg-zinc-950 dark:text-zinc-50">
    <div class="mx-auto max-w-6xl px-6">
      <header class="flex items-center justify-between gap-4 py-6">
        <a href={pathForLang("/", lang)} class="shrink-0 font-semibold tracking-tight text-zinc-900 dark:text-zinc-50">
          CodeSnip
        </a>
        <div class="flex flex-wrap items-center justify-end gap-3 sm:gap-4">
          <nav class="flex items-center gap-4 text-sm text-zinc-600 dark:text-zinc-300">
            <a class="hover:text-zinc-900 dark:hover:text-zinc-50" href={pathForLang("/features", lang)}>{t.navFeatures}</a>
            <a class="hover:text-zinc-900 dark:hover:text-zinc-50" href={pathForLang("/docs", lang)}>{t.navDocs}</a>
            <a
              class="rounded-lg bg-zinc-900 px-3 py-1.5 text-white hover:bg-zinc-700 dark:bg-white/10 dark:text-zinc-50 dark:hover:bg-white/15"
              href={pathForLang("/docs/download", lang)}
            >
              {t.navDownload}
            </a>
          </nav>
          <button
            type="button"
            id="theme-toggle"
            class="rounded-lg border border-zinc-300 bg-white px-2.5 py-1.5 text-xs font-medium text-zinc-700 hover:bg-zinc-100 dark:border-white/10 dark:bg-white/5 dark:text-zinc-300 dark:hover:bg-white/10"
            title={t.themeSwitchLabel}
            aria-label={t.themeSwitchLabel}
          >
            <span id="theme-toggle-text">{t.themeSystem}</span>
          </button>
          <div
            class="flex items-center rounded-lg border border-zinc-300 bg-zinc-100 p-0.5 text-xs font-medium text-zinc-600 dark:border-white/10 dark:bg-white/5 dark:text-zinc-300"
            role="group"
            aria-label="Language"
          >
            <a
              href={pathForLang(logical, "zh")}
              class:list={[
                "rounded-md px-2 py-1 transition-colors",
                lang === "zh"
                  ? "bg-zinc-200 text-zinc-900 dark:bg-white/15 dark:text-zinc-50"
                  : "hover:text-zinc-900 dark:hover:text-zinc-100",
              ]}
            >
              {t.langZh}
            </a>
            <a
              href={pathForLang(logical, "en")}
              class:list={[
                "rounded-md px-2 py-1 transition-colors",
                lang === "en"
                  ? "bg-zinc-200 text-zinc-900 dark:bg-white/15 dark:text-zinc-50"
                  : "hover:text-zinc-900 dark:hover:text-zinc-100",
              ]}
            >
              {t.langEn}
            </a>
          </div>
        </div>
      </header>
    </div>

    <main class="mx-auto max-w-6xl px-6 pb-20">
      <slot />
    </main>

    <footer class="border-t border-zinc-200 dark:border-white/10">
      <div class="mx-auto max-w-6xl px-6 py-10 text-sm text-zinc-500 dark:text-zinc-400">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          <div>© {new Date().getFullYear()} CodeSnip</div>
          <div class="flex gap-4">
            <a class="hover:text-zinc-700 dark:hover:text-zinc-200" href="https://tauri.app/" target="_blank" rel="noreferrer">Tauri</a>
            <a class="hover:text-zinc-700 dark:hover:text-zinc-200" href="https://astro.build/" target="_blank" rel="noreferrer">Astro</a>
          </div>
        </div>
      </div>
    </footer>
    <script is:inline define:vars={{ systemLabel: t.themeSystem, lightLabel: t.themeLight, darkLabel: t.themeDark }}>
      (() => {
        const key = "codesnip-theme";
        const root = document.documentElement;
        const btn = document.getElementById("theme-toggle");
        const text = document.getElementById("theme-toggle-text");
        if (!btn || !text) return;
        const labels = { system: systemLabel, light: lightLabel, dark: darkLabel };
        const order = ["system", "light", "dark"];
        const readPref = () => {
          const v = localStorage.getItem(key);
          return v === "light" || v === "dark" || v === "system" ? v : "system";
        };
        const apply = (pref) => {
          const dark = pref === "dark" || (pref === "system" && window.matchMedia("(prefers-color-scheme: dark)").matches);
          root.classList.toggle("dark", dark);
          root.dataset.theme = pref;
          text.textContent = labels[pref];
        };
        let current = readPref();
        apply(current);
        btn.addEventListener("click", () => {
          const idx = order.indexOf(current);
          current = order[(idx + 1) % order.length];
          localStorage.setItem(key, current);
          apply(current);
        });
        window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
          if (current === "system") apply(current);
        });
      })();
    </script>
  </body>
</html>
