---
import type { Lang } from "../i18n/strings";
import { ui } from "../i18n/strings";
import { getLogicalPath, pathForLang } from "../i18n/paths";

const { title, description, lang = "zh" } = Astro.props as {
  title: string;
  description?: string;
  lang?: Lang;
};

const t = ui[lang];
const logical = getLogicalPath(Astro.url.pathname);
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    <link rel="alternate" hreflang="zh-CN" href={pathForLang(logical, "zh")} />
    <link rel="alternate" hreflang="en" href={pathForLang(logical, "en")} />
  </head>
  <body class="min-h-dvh bg-zinc-950 text-zinc-50 antialiased">
    <div class="mx-auto max-w-6xl px-6">
      <header class="flex items-center justify-between gap-4 py-6">
        <a href={pathForLang("/", lang)} class="font-semibold tracking-tight text-zinc-50 shrink-0">
          CodeSnip
        </a>
        <div class="flex flex-wrap items-center justify-end gap-3 sm:gap-4">
          <nav class="flex items-center gap-4 text-sm text-zinc-300">
            <a class="hover:text-zinc-50" href={pathForLang("/features", lang)}>{t.navFeatures}</a>
            <a class="hover:text-zinc-50" href={pathForLang("/docs", lang)}>{t.navDocs}</a>
            <a
              class="rounded-lg bg-white/10 px-3 py-1.5 text-zinc-50 hover:bg-white/15"
              href={pathForLang("/docs/download", lang)}
            >
              {t.navDownload}
            </a>
          </nav>
          <div
            class="flex items-center rounded-lg border border-white/10 bg-white/5 p-0.5 text-xs font-medium text-zinc-300"
            role="group"
            aria-label="Language"
          >
            <a
              href={pathForLang(logical, "zh")}
              class:list={[
                "rounded-md px-2 py-1 transition-colors",
                lang === "zh" ? "bg-white/15 text-zinc-50" : "hover:text-zinc-100",
              ]}
            >
              {t.langZh}
            </a>
            <a
              href={pathForLang(logical, "en")}
              class:list={[
                "rounded-md px-2 py-1 transition-colors",
                lang === "en" ? "bg-white/15 text-zinc-50" : "hover:text-zinc-100",
              ]}
            >
              {t.langEn}
            </a>
          </div>
        </div>
      </header>
    </div>

    <main class="mx-auto max-w-6xl px-6 pb-20">
      <slot />
    </main>

    <footer class="border-t border-white/10">
      <div class="mx-auto max-w-6xl px-6 py-10 text-sm text-zinc-400">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          <div>© {new Date().getFullYear()} CodeSnip</div>
          <div class="flex gap-4">
            <a class="hover:text-zinc-200" href="https://tauri.app/" target="_blank" rel="noreferrer">Tauri</a>
            <a class="hover:text-zinc-200" href="https://astro.build/" target="_blank" rel="noreferrer">Astro</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
