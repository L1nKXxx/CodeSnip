---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { Lang } from "../i18n/strings";
import { ui } from "../i18n/strings";
import { pathForLang } from "../i18n/paths";

const { lang } = Astro.props as { lang: Lang };
const t = ui[lang];
---

<BaseLayout lang={lang} title={t.homeTitle} description={t.homeDescription}>
  <section class="py-14">
    <div class="grid gap-10 md:grid-cols-2 md:items-center">
      <div>
        <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-zinc-300">
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
          {t.badge}
        </div>
        <h1 class="mt-5 text-4xl font-semibold leading-tight tracking-tight sm:text-5xl">
          {t.heroHeading}
        </h1>
        <p class="mt-4 text-base leading-7 text-zinc-300">
          {t.heroBody}
        </p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            href={pathForLang("/docs/download", lang)}
            class="inline-flex items-center justify-center rounded-xl bg-white px-4 py-2.5 text-sm font-medium text-zinc-950 hover:bg-zinc-100"
          >
            {t.ctaDownload}
          </a>
          <a
            href={pathForLang("/features", lang)}
            class="inline-flex items-center justify-center rounded-xl border border-white/15 bg-white/5 px-4 py-2.5 text-sm font-medium text-zinc-50 hover:bg-white/10"
          >
            {t.ctaFeatures}
          </a>
        </div>
      </div>

      <div class="rounded-2xl border border-white/10 bg-gradient-to-b from-white/10 to-white/5 p-6 shadow-2xl">
        <div class="text-xs text-zinc-300">{t.previewLabel}</div>
        <pre class="mt-4 overflow-auto rounded-xl bg-zinc-950/60 p-4 text-sm leading-6 text-zinc-100">
<code is:raw>function sticky(code: string) {
  const lang = "ts";
  return { alwaysOnTop: true, opacity: 0.92, lang };
}</code>
        </pre>
        <div class="mt-4 grid grid-cols-2 gap-3 text-sm text-zinc-200">
          <div class="rounded-xl border border-white/10 bg-white/5 p-4">
            <div class="text-zinc-300">{t.cardAutoHighlight}</div>
            <div class="mt-1 font-medium">{t.cardShiki}</div>
          </div>
          <div class="rounded-xl border border-white/10 bg-white/5 p-4">
            <div class="text-zinc-300">{t.cardWindow}</div>
            <div class="mt-1 font-medium">{t.cardWindowDetail}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-3">
    <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <div class="text-sm font-medium">{t.colSticky}</div>
      <div class="mt-2 text-sm leading-6 text-zinc-300">{t.colStickyDesc}</div>
    </div>
    <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <div class="text-sm font-medium">{t.colCode}</div>
      <div class="mt-2 text-sm leading-6 text-zinc-300">{t.colCodeDesc}</div>
    </div>
    <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <div class="text-sm font-medium">{t.colShortcut}</div>
      <div class="mt-2 text-sm leading-6 text-zinc-300">{t.colShortcutDesc}</div>
    </div>
  </section>
</BaseLayout>
