---
import { getCollection } from "astro:content";

const entries = await getCollection("docs", (e) => e.slug.startsWith("en/"));
const first = entries
  .slice()
  .sort((a, b) => {
    const ag = a.data.sidebar.group.localeCompare(b.data.sidebar.group, "en");
    if (ag !== 0) return ag;
    return a.data.sidebar.order - b.data.sidebar.order;
  })[0];

if (first) {
  return Astro.redirect(`/en/docs/${first.slug.slice("en/".length)}`);
}

return Astro.redirect("/en/");
---
