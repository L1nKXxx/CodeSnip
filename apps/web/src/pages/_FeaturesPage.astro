---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { Lang } from "../i18n/strings";
import { ui } from "../i18n/strings";
import { pathForLang } from "../i18n/paths";

const { lang } = Astro.props as { lang: Lang };
const t = ui[lang];
---

<BaseLayout lang={lang} title={t.featuresTitle} description={t.featuresDescription}>
  <section class="py-10">
    <h1 class="text-3xl font-semibold tracking-tight">{t.featuresHeading}</h1>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-300">
      {t.featuresIntro}
    </p>
  </section>

  <section class="grid gap-4 md:grid-cols-2">
    <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <div class="text-sm font-medium">{t.fAlwaysOnTop}</div>
      <div class="mt-2 text-sm leading-6 text-zinc-300">
        {t.fAlwaysOnTopDesc}
      </div>
    </div>
    <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <div class="text-sm font-medium">{t.fOpacity}</div>
      <div class="mt-2 text-sm leading-6 text-zinc-300">
        {t.fOpacityDesc}
      </div>
    </div>
    <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <div class="text-sm font-medium">{t.fClickThrough}</div>
      <div class="mt-2 text-sm leading-6 text-zinc-300">
        {t.fClickThroughDesc}
      </div>
    </div>
    <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <div class="text-sm font-medium">{t.fHighlight}</div>
      <div class="mt-2 text-sm leading-6 text-zinc-300">
        {t.fHighlightDesc}
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-white/10 bg-white/5 p-6">
    <div class="text-sm font-medium">{t.fInteractions}</div>
    <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-zinc-300">
      {t.fInteractionsList.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="mt-10">
    <a
      class="inline-flex items-center justify-center rounded-xl bg-white px-4 py-2.5 text-sm font-medium text-zinc-950 hover:bg-zinc-100"
      href={pathForLang("/docs", lang)}
    >
      {t.readDocs}
    </a>
  </section>
</BaseLayout>
