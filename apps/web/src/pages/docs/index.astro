---
import { getCollection } from "astro:content";

const entries = await getCollection("docs");
const first = entries
  .slice()
  .sort((a, b) => {
    const ag = a.data.sidebar.group.localeCompare(b.data.sidebar.group, "zh-CN");
    if (ag !== 0) return ag;
    return a.data.sidebar.order - b.data.sidebar.order;
  })[0];

if (first) {
  return Astro.redirect(`/docs/${first.slug}`);
}

return Astro.redirect("/");
---

